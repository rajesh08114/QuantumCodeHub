# Example environment variables for backend.
# Application
APP_NAME=QuantumCodeHub
DEBUG=false
ENVIRONMENT=production
LOG_LEVEL=INFO

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:PASSWORD@db.REGION.supabase.co:5432/postgres
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# Redis (Upstash)
REDIS_URL=redis://default:PASSWORD@REGION.upstash.io:6379
REDIS_MAX_CONNECTIONS=50

# Authentication
SECRET_KEY=GENERATE_STRONG_SECRET_KEY_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENABLE_AUTH=false
# Optional service-to-service key for trusted backend callers (sent as X-Internal-API-Key)
INTERNAL_API_KEY=

# LLM Service (API or Local)
HF_API_KEY=hf_YOUR_HF_TOKEN_HERE
HF_INFERENCE_URL=https://router.huggingface.co/v1
HF_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct
HF_QWEN_MODEL_ID=Qwen/Qwen2.5-Coder-7B-Instruct
LLM_BACKEND=api
LLM_PROVIDER_CHAIN=hf_qwen_api
RESP_API_URL=
RESP_API_KEY=
RESP_API_MODEL=
LLM_REQUEST_TIMEOUT_SECONDS=45
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
LOCAL_MODEL_ID=ibm-granite/granite-4.0-h-small
LOCAL_MODEL_PATH=
LOCAL_MODEL_FILES_ONLY=false
MAX_TOKENS=2048
TEMPERATURE=0.3

# Token guidance (least -> balanced -> best quality)
# Least: 128-256 (fastest, short answers)
# Balanced: 512-900 (good quality/latency tradeoff)
# Best: 1200-2200 (most complete responses, higher cost/latency)
GENERATION_MAX_TOKENS=1500
TRANSPILATION_MAX_TOKENS=2000
EXPLANATION_MAX_TOKENS=1500
ERROR_FIXING_MAX_TOKENS=1800
COMPLETION_MAX_TOKENS=300
CHAT_GENERAL_MAX_TOKENS=900
SUPPORTED_PYTHON_VERSION=3.10-3.12
SUPPORTED_QISKIT_VERSION=>=1.2,<2.0
SUPPORTED_QISKIT_AER_VERSION=>=0.14,<0.16
SUPPORTED_PENNYLANE_VERSION=>=0.36,<0.39
SUPPORTED_CIRQ_VERSION=>=1.3,<1.5
SUPPORTED_TORCHQUANTUM_VERSION=>=0.1,<0.2
SUPPORTED_TORCH_VERSION=>=2.1,<2.4

# RAG Configuration
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_TOP_K=5
CHROMA_PERSIST_DIR=Rag_pipeline/chroma_db
CHROMA_COLLECTION_NAME=quantum_knowledge
RAG_DEFAULT_TO_LATEST_VERSION=true
RAG_LATEST_VERSION_CACHE_TTL_SECONDS=600
RAG_LEGACY_MODE_ALLOW_ALL_VERSIONS=true
RAG_STRICT_VERSION_SELECTION=true
# RAG retrieval tuning
# auto picks profile by endpoint/query:
# code routes -> code_heavy, explain routes -> conceptual, otherwise balanced
RAG_TRAFFIC_PROFILE=auto
RAG_FETCH_MULTIPLIER=12
RAG_MAX_FETCH_RESULTS=200
RAG_QUERY_VARIANTS=3
RAG_MAX_DOCS_PER_SOURCE=2
RAG_MAX_DOC_CHARS=1200
RAG_MAX_CONTEXT_CHARS=9000
RAG_SEMANTIC_WEIGHT=0.65
RAG_LEXICAL_WEIGHT=0.25
RAG_RRF_WEIGHT=0.10
RAG_FRAMEWORK_BOOST=0.08
RAG_RRF_K=60

# CORS
ALLOWED_ORIGINS=https://quantumcodehub.com,https://www.quantumcodehub.com

# Monitoring
SENTRY_DSN=https://YOUR_SENTRY_DSN_HERE
SENTRY_ENVIRONMENT=production

# Rate Limiting
RATE_LIMIT_FREE=50
RATE_LIMIT_PRO=500
RATE_LIMIT_TEAM=2000

# Feature Flags
ENABLE_CACHE=true
ENABLE_METRICS=true
ENABLE_RATE_LIMITING=true
LOG_HTTP_REQUEST_BODY=true
LOG_HTTP_RESPONSE_BODY=true
LOG_HTTP_BODY_MAX_CHARS=2000
LOG_HTTP_EXCLUDE_PATHS=/metrics

# Chat session memory
CHAT_ENABLE_SESSION_MEMORY=true
CHAT_CONTEXT_MESSAGES=8
CHAT_MAX_MESSAGES_PER_SESSION=120
CHAT_MAX_SESSIONS_PER_USER=100
CHAT_CROSS_SESSION_SUMMARY_COUNT=3
CHAT_SESSION_SUMMARY_MAX_CHARS=1200
CHAT_MEMORY_QUERY_MAX_CHARS=1200

# Validation and quality controls
VALIDATION_MODE=hybrid
VALIDATION_ENABLE_LLM_EVAL=true
VALIDATION_LLM_MAX_TOKENS=220
VALIDATION_LLM_ON_STATIC_PASS_ONLY=true
VALIDATION_MAX_CODE_CHARS=2400
VALIDATION_MAX_RAG_CHARS=1200
VALIDATION_MAX_COMPATIBILITY_CHARS=700
VALIDATION_USE_RAG=true
VALIDATION_RAG_TOP_K=3
VALIDATION_RAG_AUGMENT_WHEN_CONTEXT_PRESENT=false
VALIDATION_FAIL_ON_LLM_CRITICAL=true
VALIDATION_REQUIRE_LLM_PASS=false
VALIDATION_HALLUCINATION_GUARD_ENABLED=true
VALIDATION_HALLUCINATION_MIN_CODE_OVERLAP=0.22
VALIDATION_HALLUCINATION_MIN_RAG_OVERLAP=0.18
VALIDATION_HALLUCINATION_MAX_DROPPED_REPORT=8

# Modern API auto-repair
ENABLE_MODERNIZATION_REPAIR=true
MODERNIZATION_ON_DEPRECATION=true
MODERNIZATION_STRICT=true
MODERNIZATION_MAX_TOKENS=700
MODERNIZATION_APPLY_ON_GENERATE=true
MODERNIZATION_APPLY_ON_TRANSPILE=true
MODERNIZATION_APPLY_ON_FIX=true

# RL-inspired adaptive LLM routing
ENABLE_ADAPTIVE_ROUTING=true
ADAPTIVE_ROUTING_EPSILON=0.08
ADAPTIVE_ROUTING_ALPHA=0.25
ADAPTIVE_ROUTING_TARGET_LATENCY_MS=3500
